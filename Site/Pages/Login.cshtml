@page
@using Microsoft.AspNetCore.Mvc.Localization
@model Login
@inject IViewLocalizer Loc

@{
    ViewData["Title"] = Loc["Login"].Value;
    Layout = "Shared/_Layout";
}

<div class="row justify-content-center mt-4">
    <div class="col-sm-10 col-md-7 col-lg-5">

        <h2 class="mb-4">@Loc["Login"]</h2>

        @* ── Email code ────────────────────────────────────── *@
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-envelope me-2"></i>@Loc["Login with email code"]
                </h5>
                <p class="card-text text-muted small">
                    @Loc["Enter your e-mail address. We will send you a one-time code to verify your identity."]
                </p>
                <form method="post" action="/account/loginmessage">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="mode" value="21" />
                    @if (Model.ReturnUrl != null)
                    {
                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    }
                    <div class="input-group">
                        <input type="email"
                               class="form-control"
                               name="emailAddress"
                               placeholder="@Loc["your@email.com"].Value"
                               autocomplete="email"
                               required
                               autofocus />
                        <button type="submit" class="btn btn-primary">
                            @Loc["Send code"]
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @* ── Google (Phase 2 placeholder) ─────────────────── *@
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">
                    <svg class="me-2" style="width:1.1em;height:1.1em;vertical-align:-.15em" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                    </svg>@Loc["Login with Google"]
                </h5>
                <p class="card-text text-muted small">
                    @Loc["Google login is not yet available. It will be introduced in a future update."]
                </p>
                <button class="btn btn-outline-secondary" disabled title="@Loc["Coming soon"].Value">
                    @Loc["Continue with Google"]
                </button>
            </div>
        </div>

    </div>
</div>
